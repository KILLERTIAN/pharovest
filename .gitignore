# Standard Node.js ignore
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Hardhat / Blockchain
artifacts/
cache/
typechain/
typechain-types/
coverage/
coverage.json
.hardhat/
/backend/artifacts
/backend/cache
/backend/typechain-types
/backend/ignition/deployments

# Environment
.env
.env.*
!.env.example
/backend/.env
/frontend/.env

# IDE / Operating System
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.direnv/
.cache/

# Cloudflare / Vite / NPM specific
.mf/
.vite/
/frontend/.vite/
/frontend/.npm-cache/
.npm-cache/

# Asset Exclusions (Keep only what you want in git)
*.zip
*.tar.gz
*.tgz
*.log

# Allow specific useful icons/images but ignore others if needed
# (Adjust as per your media strategy)
# !/frontend/src/assets/**/*.png
# !/frontend/public/**/*.png
# Extra / Temp scripts
check-blockchain-project.cjs
sync-project-11-sepolia.js
backend/scripts/sync-project-11-sepolia.js
backend/scripts/*-temp.js
backend/deployment-*.json
